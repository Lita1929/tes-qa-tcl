{
  "info": {
    "name": "QA API Test",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET /posts",
      "request": {
        "method": "GET",
        "url": "https://jsonplaceholder.typicode.com/posts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is array\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"Each post has required fields\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData[0]).to.have.property(\"userId\");",
              "    pm.expect(jsonData[0]).to.have.property(\"id\");",
              "    pm.expect(jsonData[0]).to.have.property(\"title\");",
              "    pm.expect(jsonData[0]).to.have.property(\"body\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /posts/1",
      "request": {
        "method": "GET",
        "url": "https://jsonplaceholder.typicode.com/posts/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Correct ID returned\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.id).to.eql(1);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /posts/101",
      "request": {
        "method": "GET",
        "url": "https://jsonplaceholder.typicode.com/posts/101"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 404\", function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "GET /posts/a",
      "request": {
        "method": "GET",
        "url": "https://jsonplaceholder.typicode.com/posts/a"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 404\", function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /posts (VALID)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": 1,\n  \"title\": \"test\",\n  \"body\": \"test 1\"\n}"
        },
        "url": "https://jsonplaceholder.typicode.com/posts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response has id\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"id\");",
              "});",
              "",
              "pm.test(\"Response matches request\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.userId).to.eql(1);",
              "    pm.expect(jsonData.title).to.eql(\"test\");",
              "    pm.expect(jsonData.body).to.eql(\"test 1\");",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /posts (Empty Body)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}"
        },
        "url": "https://jsonplaceholder.typicode.com/posts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Check response still created\", function () {",
              "    pm.response.to.have.status(201);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "POST /posts (Invalid JSON)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{ \"title\": test }"
        },
        "url": "https://jsonplaceholder.typicode.com/posts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status should indicate error\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([400, 500]);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}